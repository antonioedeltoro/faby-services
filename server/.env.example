# server/.env — copy to .env and fill in real values (never commit .env)

# Admin login (single hardcoded admin used by /api/auth/login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Secret used to sign/verify JWTs (use a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Allowed browser origin for CORS in local dev
CLIENT_ORIGIN=http://localhost:5173
